# Copy this file to .env and fill in your real values.
# .env is gitignored; .env.example is committed as a template.

# Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Provider selector (currently only 'anthropic' is implemented; leave empty to disable)
COMPLY_LLM=anthropic

# Model to use. Recommended:
#   claude-sonnet-4-5    fast, cheap, good for rule-following (default)
#   claude-opus-4-5      slower, more expensive, better at edge cases
COMPLY_LLM_MODEL=claude-sonnet-4-5

# Per-day spend cap (USD). Server returns 429 when reached.
COMPLY_LLM_BUDGET_USD_PER_DAY=5.00
